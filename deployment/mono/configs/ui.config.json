{
  "name": "converged-portal",
  "container": "ui",
  "landing": "front/landing",
  "spa": {
    "core": "front/front-core",
    "microfrontends": [
      "auth",
      "agents",
      "assistants",
      "functions",
      "community",
      "charts",
      "calls",
      "classifier",
      "dag",
      "dasboards",
      "dumps",
      "docs",
      "galery",
      "landing",
      "logs",
      "markdown",
      "static",
      "struct",
      "orders",
      "requests",
      "sheduller",
      "telemetry",
      "threads",
      "usage",
      "webhooks"
    ]
  },
  "localization": {
    "mode": "single",
    "locale": "en"
  },
  "back": {
    "core": "back/back-core",
    "microservices": {}
  },
  "frontend": {
    "modules": {
      "auth": true,
      "agents": true,
      "assistants": true,
      "functions": true,
      "community": true,
      "charts": true,
      "calls": true,
      "classifier": true,
      "dag": true,
      "dasboards": true,
      "dumps": true,
      "docs": true,
      "galery": true,
      "landing": true,
      "logs": true,
      "markdown": true,
      "static": true,
      "struct": true,
      "orders": true,
      "requests": true,
      "sheduller": true,
      "telemetry": true,
      "threads": true,
      "usage": true,
      "webhooks": true
    },
    "layout": "sidebar",
    "mountChatView": true
  },
  "cache": {
    "url": "redis://127.0.0.1:6379/0",
    "keyPrefix": "converged-portal",
    "ssrTtlSeconds": 120
