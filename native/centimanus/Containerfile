FROM alpine:3.23.4 AS centimanus
WORKDIR /app

# TLS roots for the LLM provider hub (api.openai.com / api.anthropic.com /
# generativelanguage.googleapis.com).
RUN apk add --no-cache ca-certificates

RUN mkdir -p /app/lib
COPY ./.container-bin/centimanus /app/centimanus
COPY ./.container-bin/libqjs.so /app/lib/libqjs.so
COPY ./.container-libs/libzimq.so /app/lib/libzimq.so
RUN chmod +x /app/centimanus && chown -R 1000:1000 /app
RUN adduser -D -u 1000 default || true
USER 1000

ENV CENTIMANUS_FUJIN_ZMQ_ENDPOINT=tcp://127.0.0.1:5557 \
    CENTIMANUS_FUJIN_ZIMQ_LIB=/app/lib/libzimq.so \
    LD_LIBRARY_PATH=/app/lib

EXPOSE 9000

CMD ["/app/centimanus", "0.0.0.0:9000"]
