{
  "name": "converged-portal",
  "description": "Converged Portal — full platform",
  "baseImage": "docker.io/oven/bun:1.3-alpine",
  "registry": "public.ecr.aws/i5x9u8b2",
  "landing": "front/landing",
  "localization": {
    "mode": "single",
    "locale": "en"
  },
  "runtimeDeps": {
    "packages": {
      "sharp": "latest"
    },
    "apk": ["vips"]
  },
  "cache": {
    "image": "docker.io/valkey/valkey:8.1-alpine",
    "port": 6379,
    "database": 0,
    "keyPrefix": "converged-portal",
    "ssrTtlSeconds": 120,
    "resources": {
      "requests": {
        "cpu": "50m",
        "memory": "64Mi"
      },
      "limits": {
        "cpu": "500m",
        "memory": "256Mi"
      }
    }
  },
  "spa": {
    "core": "front/front-core",
    "microfrontends": [
      "auth",
      "agents",
      "assistants",
      "contexts",
      "functions",
      "community",
      "charts",
      "calls",
      "classifier",
      "dag",
      "dasboards",
      "dumps",
      "docs",
      "galery",
      "landing",
      "logs",
      "markdown",
      "static",
      "struct",
      "orders",
      "requests",
      "sheduller",
      "telemetry",
      "threads",
      "usage",
      "webhooks"
    ]
  },
  "back": {
    "core": "back/back-core",
    "runtimes": {
      "automation": ["dag", "cron", "gates"],
      "ai": ["agents", "assistant"]
    },
    "microservices": {
      "ai": ["agent", "assistant", "contexts", "functions"],
      "analytics": ["dashboard", "logs", "telemetry", "usage"],
      "automation": ["dag", "sheduller", "webhooks"],
      "convertors": ["modelconvertor"],
      "business": [
        "billing",
        "equipment",
        "events",
        "orders",
        "partners",
        "requests",
        "reviews",
        "sales",
        "staff"
      ],
      "communications": [
        "audio-gate",
        "calls",
        "chats",
        "community",
        "notify",
        "threads"
      ],
      "content": [
        "ceo",
        "classifier",
        "galery",
        "markdown",
        "scripts",
        "static",
        "struct",
        "video"
      ],
      "data": ["dumps", "files", "store"],
      "delivery": ["delivery", "dhl", "ems", "fedex", "sfexpress", "ups"],
      "extractors": ["millingextractor", "printextractor"],
      "providers": ["push", "ses", "sms", "smtp"],
      "sequrity": ["access", "auth", "identity", "modules", "oauth", "secrets"],
      "social": [
        "discord",
        "facebook",
        "instagram",
        "telegram",
        "tiktok",
        "wechat",
        "youtube"
      ]
    }
  },
  "sections": {
    "mono": {
      "type": "mono",
      "description": "Single node, one client (ui + ms + rt + store + gate)",
      "resources": {
        "ms": {
          "requests": { "cpu": "100m", "memory": "128Mi" },
          "limits": { "cpu": "1000m", "memory": "1Gi" }
        }
      }
    },
    "multi": {
      "type": "multi",
      "description": "One client across nodes; store sharded by scope",
      "shards": [
        { "name": "files", "scopes": ["files", "dumps"], "size": "200Gi" },
        { "name": "main", "scopes": ["*"] }
      ]
    },
    "cloud": {
      "type": "cloud",
      "description": "Multi-tenant SaaS; store and runtime provisioned per tenant by the operator",
      "resources": {
        "ms": {
          "requests": { "cpu": "50m", "memory": "128Mi" },
          "limits": { "cpu": "1000m", "memory": "1Gi" }
        }
      }
    }
  },
  "storage": {
    "defaultSize": "5Gi",
    "mountBase": "/app/data",
    "port": 9000,
    "devPort": 9000,
    "resources": {
      "requests": {
        "cpu": "50m",
        "memory": "128Mi"
      },
      "limits": {
        "cpu": "1000m",
        "memory": "2Gi"
      }
    },
    "overrides": {
      "files": {
        "size": "100Gi"
      },
      "dumps": {
        "size": "50Gi"
      },
      "store": {
        "size": "20Gi"
      }
    }
  },
  "tools": {
    "llmAudioGate": {
      "enabled": true,
      "image": "public.ecr.aws/i5x9u8b2/llm-audio-gate:latest",
      "port": 8090,
      "ingress": {
        "paths": ["/audio-gate"],
        "routeTo": "services"
      },
      "resources": {
        "requests": {
          "cpu": "50m",
          "memory": "64Mi"
        },
        "limits": {
          "cpu": "500m",
          "memory": "256Mi"
        }
      }
    }
  },
  "ingress": {
    "className": "traefik",
    "hosts": ["*.4ir.club", "*.local.4ir.club"],
    "tls": {
      "enabled": true,
      "secretName": "4ir-club-tls"
    }
  },
  "frontend": {
    "mountChatViewModule": "assistants"
  },
  "env": {
    "common": {
      "NODE_ENV": "production"
    },
    "secrets": [
      "CHAT_PROVIDER",
      "CHAT_MODEL",
      "OPENAI_API_KEY",
      "OPENAI_MODEL",
      "CLAUDE_API_KEY",
      "CLAUDE_MODEL",
      "GEMINI_API_KEY",
      "GEMINI_MODEL",
      "JWT_SECRET",
      "ACCESS_JWT_SECRET",
      "ACCESS_JWT_TTL",
      "NRPC_ACCESS_MODE",
      "ROOT_EMAIL"
    ]
  }
}
