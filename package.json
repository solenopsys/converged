{
	"name": "converged-portal",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"workspaces": [
		"back/back-core",
		"back/external/*",
		"back/native/*",
		"back/workflows",
		"back/runtime",
		"back/microservices/**/*",
		"front/front-core",
		"front/landing",
		"front/libraries/*",
		"front/microfrontends/**/*",
		"front/spa",
		"front/ssr",
		"tools/*",
		"tools/integration/*",
		"tools/integration/generated/*",
		"native/behemoth/*"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@playwright/test": "^1.59.1",
		"@types/bun": "^1.3.12",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/static": "^1.4.7",
		"@tabler/icons": "^3.41.1",
		"@tabler/icons-react": "^3.41.1",
		"@textea/json-viewer": "^4.0.1",
		"@types/node": "^25.6.0",
		"@typescript-eslint/typescript-estree": "^8.58.1",
		"@unocss/preset-icons": "^66.6.8",
		"@unocss/reset": "^66.6.8",
		"bun-transport": "workspace:*",
		"cdk8s": "^2.70.54",
		"cdk8s-plus-31": "^2.6.43",
		"constructs": "^10.6.0",
		"croner": "^10.0.1",
		"elysia": "^1.4.28",
		"globals": "^17.4.0",
		"i18next": "^26.0.4",
		"i18next-http-backend": "^3.0.4",
		"jose": "^6.2.2",
		"lightningcss": "^1.32.0",
		"lucide-react": "^1.8.0",
		"msgpackr": "^1.11.9",
		"pixi.js": "^8.17.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-i18next": "^17.0.2",
		"react-router": "^7.14.0",
		"react-router-dom": "^7.14.0",
		"tailwind-merge": "^3.5.0",
		"unocss": "^66.6.8",
		"uuid": "^13.0.0",
		"yaml": "^2.8.3"
	},
	"scripts": {
		"dev": "NODE_ENV=development bun run --cwd tools/configurator src/cli.ts dev --project=converged-portal --env-file=../../confs/converged-portal.env",
		"build:mono": "BOOTSTRAP_ENV_DIR=../../confs bun run --cwd tools/configurator src/cli.ts build --project=converged-portal --preset=mono --output=../../deployment",
		"build:multi": "BOOTSTRAP_ENV_DIR=../../confs bun run --cwd tools/configurator src/cli.ts build --project=converged-portal --preset=multi --output=../../deployment",
		"secrets": "bun run --cwd tools/configurator src/cli.ts secrets --project=converged-portal --output=../../../../deployment",
		"build:container:ui": "podman build --layers --ignorefile ./deployment/mono/containers/.containerignore -f ./deployment/mono/containers/converged-portal.ui.Containerfile -t converged-portal-ui ../../..",
		"build:container:ms": "podman build --layers --ignorefile ./deployment/mono/containers/.containerignore -f ./deployment/mono/containers/converged-portal.ms.Containerfile -t converged-portal-ms ../../..",
		"build:container:rt": "podman build --layers --ignorefile ./deployment/mono/containers/.containerignore -f ./deployment/mono/containers/converged-portal.rt.Containerfile -t converged-portal-rt ../../..",
		"cli": "bun run --env-file=../../confs/cli-dev.env tools/cli/src/cli.ts --commands=tools/commands",
		"clip": "bun run --env-file=../../cli-prod.env tools/cli/src/cli.ts --commands=tools/commands",
		"k3s:import": "podman save converged-portal:latest -o /tmp/converged-portal.tar && sudo k3s ctr images import /tmp/converged-portal.tar && rm /tmp/converged-portal.tar",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"gen": "bun run --cwd tools/integration/nrpc src/gen-all.ts ../types ../generated",
		"store-check": "BOOTSTRAP_ENV_DIR=../../confs bun run --env-file=../../confs/converged-portal.env tools/store-check.ts",
		"test:transport": "bun tools/transport-integration.ts"
	}
}
