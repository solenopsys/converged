{
  "name": "converged-portal",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "back/back-core",
    "back/runtimes/**/*",
    "back/external/*",
    "back/native/*",
    "back/runtime",
    "back/microservices/**/*",
    "front/front-core",
    "front/landing",
    "front/libraries/*",
    "front/microfrontends/**/*",
    "front/spa",
    "front/ssr",
    "tools/*",
    "tools/integration/*",
    "tools/integration/generated/*",
    "native/behemoth/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.14",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@tabler/icons": "^3.44.0",
    "@tabler/icons-react": "^3.44.0",
    "@textea/json-viewer": "^4.0.1",
    "@types/node": "^25.9.4",
    "@typescript-eslint/typescript-estree": "^8.61.1",
    "@unocss/preset-icons": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "bun-transport": "workspace:*",
    "croner": "^10.0.1",
    "elysia": "^1.4.29",
    "fflate": "^0.8.3",
    "g-agent": "workspace:*",
    "g-files": "workspace:*",
    "g-millingextractor": "workspace:*",
    "g-modelconvertor": "workspace:*",
    "g-printextractor": "workspace:*",
    "g-sales": "workspace:*",
    "g-smtp": "workspace:*",
    "g-store": "workspace:*",
    "globals": "^17.6.0",
    "i18next": "^26.3.1",
    "i18next-http-backend": "^3.0.6",
    "jose": "^6.2.3",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.21.0",
    "msgpackr": "^1.12.1",
    "pixi.js": "^8.19.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.8",
    "react-router": "^7.18.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "unocss": "^66.7.2",
    "uuid": "^13.0.2",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "dev": "bun i && NODE_ENV=development bun run --cwd ../club-portal/tools/configurator src/cli.ts dev --project=converged-portal --env-file=../../confs/converged-portal-local.env",
    "build:mono": "bun run --cwd ../club-portal cli release helm converged-portal mono",
    "build:cloud": "bun run --cwd ../club-portal cli release helm converged-portal cloud",
    "build:ui": "bun run --cwd ../club-portal cli release ship converged-portal ui",
    "build:ms": "bun run --cwd ../club-portal cli release ship converged-portal ms",
    "build:rt": "bun run --cwd ../club-portal cli release ship converged-portal rt",
    "build:all": "bun build:ui -p && bun build:ms -p && bun build:rt -p",
    "build:storage": "bun run --cwd ../club-portal cli release ship converged-portal storage",
    "cli": "bun run --env-file=../../confs/cli-dev.env tools/cli/src/cli.ts --commands=tools/commands",
    "clip": "bun run --env-file=../../cli-prod.env tools/cli/src/cli.ts --commands=tools/commands",
    "secrets": "bun run --cwd ../club-portal/tools/configurator src/cli.ts secrets --project=converged-portal --output=/home/alexstorm/distrib/4ir/gestalt/clarity/confs",
    "k3s:import": "podman save converged-portal:latest -o /tmp/converged-portal.tar && sudo k3s ctr images import /tmp/converged-portal.tar && rm /tmp/converged-portal.tar",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "storybook": "bun run --cwd tools/storybook sb",
    "storybook:build": "bun run --cwd tools/storybook build-storybook",
    "gen": "bun run --cwd tools/integration/nrpc src/gen-all.ts ../types ../generated",
    "store-check": "BOOTSTRAP_ENV_DIR=../../confs bun run --env-file=../../confs/converged-portal.env tools/store-check.ts",
    "test:transport": "bun tools/transport-integration.ts"
  }
}
